{
  "manifest_version": 3,
  "name": "FlowTab",
  "short_name": "FlowTab",
  "version": "0.1.0",
  "description": "A simple, personalized new tab with local-first data storage.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage", "search"]
}
